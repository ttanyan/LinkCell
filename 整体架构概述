class BaseResetProblemStep(IBaseChatPipelineStep):
    """
    问题优化步骤
    
    功能:
    - 结合历史对话优化当前问题
    - 使问题更清晰、完整
    
    输入:
    - problem_text: 原始问题
    - history_chat_record: 历史对话记录
    - model_id: 用于优化的模型
    
    输出:
    - padding_problem_text: 优化后的问题
    """
    
    def _run(self, manage):
        args = self.context['step_args']
        padding_problem = self.execute(**args)
        
        # 写入上下文供后续步骤使用
        manage.context['padding_problem_text'] = padding_problem
        manage.context['problem_text'] = args['problem_text']
