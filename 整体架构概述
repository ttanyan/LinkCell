```python
class IBaseChatPipelineStep:
    """
    流水线步骤基类
    
    每个步骤的职责:
    1. 验证输入参数
    2. 执行业务逻辑
    3. 将结果写入 manage.context
    """
    
    def __init__(self):
        self.context = {}  # 当前步骤的上下文
    
    def run(self, manage: PipelineManage):
        """
        运行步骤（模板方法）
        
        流程:
        1. 记录开始时间
        2. 验证参数
        3. 执行具体逻辑 (_run)
        4. 记录运行时间
        """
        start_time = time.time()
        self.valid_args(manage)  # 验证参数
        self._run(manage)         # 执行逻辑
        self.context['run_time'] = time.time() - start_time
    
    def valid_args(self, manage):
        """验证参数（使用 Serializer）"""
        serializer_class = self.get_step_serializer(manage)
        serializer = serializer_class(data=manage.context)
        serializer.is_valid(raise_exception=True)
        self.context['step_args'] = serializer.data
    
    @abstractmethod
    def get_step_serializer(self, manage) -> Type[Serializer]:
        """返回参数验证器"""
        pass
    
    @abstractmethod
    def _run(self, manage):
        """执行步骤逻辑（子类实现）"""
        pass
    
    def execute(self, **kwargs):
        """直接执行步骤（不经过流水线）"""
        pass
