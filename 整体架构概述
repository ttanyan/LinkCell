class BaseGenerateHumanMessageStep(IBaseChatPipelineStep):
    """
    生成人类消息步骤
    
    功能:
    - 构建完整的消息列表
    - 包含系统提示词、历史对话、知识段落
    
    输入:
    - problem_text: 问题
    - paragraph_list: 知识段落
    - history_chat_record: 历史对话
    - prompt: 提示词模板
    - dialogue_number: 历史对话轮数
    
    输出:
    - message_list: 完整的消息列表
    """
    
    def execute(self, problem_text, paragraph_list, history_chat_record,
                dialogue_number, max_paragraph_char_number, prompt, ...):
        """
        构建消息列表
        
        Returns:
            List[BaseMessage]: [
                SystemMessage(system_prompt),
                HumanMessage(history_1),
                AIMessage(history_1_answer),
                ...,
                HumanMessage(current_question_with_context)
            ]
        """
        # 1. 处理提示词模板
        prompt = prompt if paragraph_list else no_references_setting['value']
        
        # 2. 获取历史对话
        start_index = len(history_chat_record) - dialogue_number
        history_messages = [
            [record.get_human_message(), record.get_ai_message()]
            for record in history_chat_record[start_index:]
        ]
        
        # 3. 构建当前问题消息（包含知识段落）
        current_message = self.to_human_message(
            prompt, problem_text, max_paragraph_char_number, paragraph_list
        )
        
        # 4. 组装完整消息列表
        return [
            SystemMessage(system_prompt),
            *flat_map(history_messages),  # 展平历史对话
            current_message
        ]
