**文件**: `application/chat_pipeline/pipeline_manage.py`

```python
class PipelineManage:
    """
    对话流水线管理器 - 责任链模式
    
    执行流程:
    1. 初始化所有步骤
    2. 依次执行每个步骤
    3. 步骤间通过 context 传递数据
    """
    
    def __init__(self, step_list, base_to_response=None, debug=False):
        self.step_list = [step() for step in step_list]  # 实例化步骤
        self.context = {
            'message_tokens': 0,
            'answer_tokens': 0,
            'start_time': None
        }
        self.base_to_response = base_to_response  # 响应格式化器
        self.debug = debug
    
    def run(self, context: Dict):
        """
        运行流水线
        
        Args:
            context: 包含所有需要的参数
                - problem_text: 用户问题
                - chat_id: 对话ID
                - model_id: 模型ID
                - stream: 是否流式输出
                - post_response_handler: 后置处理器
                - ... 其他参数
        """
        self.context['start_time'] = time.time()
        
        # 合并传入的上下文
        self.context.update(context)
        
        # 依次执行每个步骤
        for step in self.step_list:
            step.run(self)  # 每个步骤可以访问和修改 self.context
        
        # 返回最终结果
        return self.context.get('chat_result')
    
    class Builder:
        """建造者模式构建 PipelineManage"""
        def __init__(self):
            self.step_list = []
            self.base_to_response = SystemToResponse()
            self.debug = False
        
        def append_step(self, step_class):
            self.step_list.append(step_class)
            return self
        
        def add_base_to_response(self, handler):
            self.base_to_response = handler
            return self
        
        def build(self):
            return PipelineManage(
                step_list=self.step_list,
                base_to_response=self.base_to_response,
                debug=self.debug
            )
```

