class BaseChatStep(IChatStep):
    """
    模型对话步骤 - 核心步骤
    
    功能:
    - 调用模型进行对话
    - 支持流式和非流式输出
    - 处理工具调用（MCP）
    - 统计 Token 消耗
    
    输入:
    - message_list: 消息列表
    - model_id: 模型ID
    - stream: 是否流式输出
    - chat_id: 对话ID
    - post_response_handler: 后置处理器
    
    输出:
    - chat_result: 对话结果（流式响应或完整响应）
    """
    
    def execute(self, message_list, chat_id, problem_text,
                post_response_handler, model_id, workspace_id,
                paragraph_list, manage, stream=True, ...):
        """
        执行对话
        
        Returns:
            StreamingHttpResponse 或 dict
        """
        # 1. 获取模型实例
        chat_model = get_model_instance_by_model_workspace_id(
            model_id, workspace_id, **model_params_setting
        ) if model_id else None
        
        # 2. 根据流式标志选择执行方式
        if stream:
            return self.execute_stream(
                message_list, chat_id, problem_text,
                post_response_handler, chat_model, paragraph_list, manage, ...
            )
        else:
            return self.execute_block(...)
    
    def execute_stream(self, message_list, chat_id, problem_text,
                      post_response_handler, chat_model, paragraph_list,
                      manage, ...):
        """
        流式对话执行
        
        Returns:
            StreamingHttpResponse: SSE 格式的流式响应
        """
        # 1. 获取流式结果
        chat_result, is_ai_chat = self.get_stream_result(
            message_list, chat_model, paragraph_list, ...
        )
        
        # 2. 生成对话记录ID
        chat_record_id = uuid.uuid7()
        
        # 3. 创建流式响应
        response = StreamingHttpResponse(
            streaming_content=event_content(
                chat_result, chat_id, chat_record_id,
                paragraph_list, post_response_handler,
                manage, self, ...
            ),
            content_type='text/event-stream'
        )
        
        return response
    
    def get_stream_result(self, message_list, chat_model, paragraph_list, ...):
        """
        获取流式对话结果
        
        Returns:
            Iterator[AIMessageChunk]: 模型输出的流
            bool: 是否是 AI 对话
        """
        if chat_model is None:
            return iter([AIMessageChunk("模型未配置")]), False
        
        # 处理 MCP 工具调用
        mcp_result = self._handle_mcp_request(...)
        if mcp_result:
            return mcp_result, True
        
        # 调用模型流式接口
        return chat_model.stream(message_list), True


def event_content(response, chat_id, chat_record_id, paragraph_list,
                 post_response_handler, manage, step, ...):
    """
    事件内容生成器 - 处理流式响应
    
    功能:
    - 逐块读取模型输出
    - 格式化为 SSE 事件
    - 统计 Token
    - 保存对话记录
    
    Yields:
        str: SSE 格式的事件字符串
    """
    all_text = ''
    reasoning_content = ''
    
    try:
        # 1. 逐块处理模型输出
        for chunk in response:
            # 提取内容和推理内容
            content_chunk = extract_content(chunk)
            reasoning_chunk = extract_reasoning_content(chunk)
            
            all_text += content_chunk
            reasoning_content += reasoning_chunk
            
            # 2. 发送 SSE 事件
            yield manage.base_to_response.to_stream_chunk_response(
                chat_id, chat_record_id, 'ai-chat-node',
                [], content_chunk, False, 0, 0,
                {'reasoning_content': reasoning_content}
            )
        
        # 3. 计算 Token 数量
        request_token = chat_model.get_num_tokens_from_messages(message_list)
        response_token = chat_model.get_num_tokens(all_text)
        
        # 4. 更新上下文
        step.context['message_tokens'] = request_token
        step.context['answer_tokens'] = response_token
        step.context['answer_text'] = all_text
        
        # 5. 调用后置处理器（保存对话记录）
        post_response_handler.handler(
            chat_id, chat_record_id, paragraph_list,
            problem_text, all_text, manage, step, ...
        )
        
        # 6. 发送结束事件
        yield manage.base_to_response.to_stream_chunk_response(
            chat_id, chat_record_id, 'ai-chat-node',
            [], '', True, request_token, response_token,
            {'node_is_end': True}
        )
        
    except Exception as e:
        # 错误处理
        yield error_response(...)
