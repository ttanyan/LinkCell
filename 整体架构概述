def get_provider(provider_name):
    """根据提供商名称获取提供商实例"""
    return ModelProvideConstants[provider_name].value

def get_model_instance_by_model_workspace_id(model_id, workspace_id, **kwargs):
    """
    根据模型 ID 获取模型实例（带缓存）
    
    流程:
    1. 从数据库查询模型配置
    2. 解密凭证
    3. 获取提供商
    4. 创建模型实例
    5. 缓存实例
    """
    model = get_model_by_id(model_id, workspace_id)
    provider = get_provider(model.provider)
    credential = decrypt(model.credential)  # RSA 解密
    return provider.get_model(
        model.model_type, 
        model.model_name, 
        credential, 
        **kwargs
    )
